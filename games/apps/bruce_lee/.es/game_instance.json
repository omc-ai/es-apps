  {
    "id": "c64_brucelee_mem",
    "class_id": "game:memory_map",
    "name": "Bruce Lee C64 Memory Map",
    "total_size": 65536,
    "regions": [
      {"name": "zero_page", "start": "0x0000", "end": "0x00FF", "type": "zeropage", "description": "Character arrays and game state variables"},
      {"name": "game_code", "start": "0x0400", "end": "0x0CFF", "type": "code", "description": "Main game logic routines"},
      {"name": "room_header", "start": "0x0153", "end": "0x0166", "type": "data", "description": "Per-room config (20 bytes copied during room setup)"},
      {"name": "enemy_flags_1", "start": "0x1333", "end": "0x1346", "type": "data", "description": "Enemy behavior flags table 1 (20 rooms)"},
      {"name": "enemy_flags_2", "start": "0x136F", "end": "0x1382", "type": "data", "description": "Enemy behavior flags table 2 (20 rooms)"},
      {"name": "sprite_tables", "start": "0x2763", "end": "0x2782", "type": "data", "description": "Sprite pair mapping, MSB masks, enable masks"},
      {"name": "screen_draw_ptrs", "start": "0x43BE", "end": "0x43FF", "type": "data", "description": "Screen drawing routine pointers"},
      {"name": "room_colors", "start": "0x47A0", "end": "0x47B3", "type": "data", "description": "Per-room color bytes (20 rooms)"},
      {"name": "room_decor", "start": "0x490D", "end": "0x4A34", "type": "data", "description": "Room decoration tables"},
      {"name": "room_layout_ptrs", "start": "0x4AA8", "end": "0x4ACF", "type": "data", "description": "Room layout data pointers (20x2 bytes)"},
      {"name": "room_layout_data", "start": "0x4AD0", "end": "0x4BAD", "type": "data", "description": "Compressed room layout data (RLE)"},
      {"name": "bruce_start_x", "start": "0x4BAE", "end": "0x4BC1", "type": "data", "description": "Bruce starting X per room (20 bytes)"},
      {"name": "bruce_start_y", "start": "0x4BC2", "end": "0x4BD5", "type": "data", "description": "Bruce starting Y per room (20 bytes)"},
      {"name": "enemy_start_x", "start": "0x4BD6", "end": "0x4BE9", "type": "data", "description": "Enemy starting X per room (20 bytes)"},
      {"name": "enemy_start_y", "start": "0x4BEA", "end": "0x4BFD", "type": "data", "description": "Enemy starting Y per room (20 bytes)"},
      {"name": "room_exit_flags", "start": "0x4C9E", "end": "0x4CB1", "type": "data", "description": "Room exit condition flags (20 bytes)"},
      {"name": "sprite_data", "start": "0x8000", "end": "0x83FF", "type": "sprite", "bank": 2, "description": "Sprite blocks 0-15 (characters)"},
      {"name": "sprite_bg", "start": "0x8400", "end": "0x87FF", "type": "sprite", "bank": 2, "description": "Sprite blocks 16-31 (background patterns)"},
      {"name": "game_charset", "start": "0x8800", "end": "0x8FFF", "type": "charset", "bank": 2, "description": "Game charset (256 chars, multicolor)"},
      {"name": "screen_ram", "start": "0x8C00", "end": "0x8FF7", "type": "screen", "bank": 2, "description": "Screen RAM (40x25 char indices)"},
      {"name": "sprite_pointers", "start": "0x8FF8", "end": "0x8FFF", "type": "data", "bank": 2, "description": "Sprite block pointers (8 bytes)"},
      {"name": "color_ram", "start": "0xD800", "end": "0xDBE7", "type": "color", "description": "Color RAM (per-cell colors, always at this address)"},
      {"name": "vic_registers", "start": "0xD000", "end": "0xD02E", "type": "io", "description": "VIC-II video chip registers"},
      {"name": "sid_registers", "start": "0xD400", "end": "0xD41C", "type": "io", "description": "SID sound chip registers"},
      {"name": "cia1", "start": "0xDC00", "end": "0xDC0F", "type": "io", "description": "CIA1 (joystick, keyboard)"}
    ],
    "bank_config": {
      "type": "vic_bank",
      "active_bank": 2,
      "bank_start": "0x8000",
      "bank_size": 16384,
      "register": "0xDD00"
    },
    "zeropage_vars": [
      {"address": "0x29", "name": "room_number", "size": 1, "description": "Current room (0-19)"},
      {"address": "0x28", "name": "lives", "size": 1, "description": "Lives remaining"},
      {"address": "0x47", "name": "sprite_enable_shadow", "size": 1, "description": "Shadow of $D015"},
      {"address": "0x51", "name": "character_index", "size": 1, "description": "Current character being processed"},
      {"address": "0x8A", "name": "temp_flag", "size": 3, "indexed_by": "char_index", "description": "Temporary flag"},
      {"address": "0x95", "name": "state_flags", "size": 3, "indexed_by": "char_index", "description": "Active/direction/jumping/climbing bitmask"},
      {"address": "0x98", "name": "anim_frame", "size": 3, "indexed_by": "char_index", "description": "Current animation frame"},
      {"address": "0x9B", "name": "direction", "size": 3, "indexed_by": "char_index", "description": "Facing direction"},
      {"address": "0x9E", "name": "pos_x", "size": 3, "indexed_by": "char_index", "description": "X position (game coords, *2 for screen)"},
      {"address": "0xA1", "name": "pos_y", "size": 3, "indexed_by": "char_index", "description": "Y position (+29 for VIC sprite Y)"},
      {"address": "0xA4", "name": "move_state", "size": 3, "indexed_by": "char_index", "description": "Velocity / movement state"},
      {"address": "0xA9", "name": "gravity_counter", "size": 3, "indexed_by": "char_index", "description": "Gravity counter"},
      {"address": "0xB6", "name": "health", "size": 3, "indexed_by": "char_index", "description": "Health/timer (most read variable)"},
      {"address": "0xBC", "name": "combat_state", "size": 3, "indexed_by": "char_index", "description": "Combat state"},
      {"address": "0xBF", "name": "attack_timer", "size": 3, "indexed_by": "char_index", "description": "Attack timer"},
      {"address": "0xC2", "name": "attack_type", "size": 3, "indexed_by": "char_index", "description": "Attack type"},
      {"address": "0xCB", "name": "char_color", "size": 3, "indexed_by": "char_index", "description": "Character color"},
      {"address": "0xCE", "name": "stun_timer", "size": 3, "indexed_by": "char_index", "description": "Stun/damage timer"},
      {"address": "0xD0", "name": "spr_pair_block", "size": 3, "indexed_by": "char_index", "description": "Sprite pair block number"},
      {"address": "0xD1", "name": "spr_main_block", "size": 3, "indexed_by": "char_index", "description": "Sprite main block number"},
      {"address": "0xE0", "name": "height_state", "size": 3, "indexed_by": "char_index", "description": "Jump height state"},
      {"address": "0xE9", "name": "speed_val", "size": 3, "indexed_by": "char_index", "description": "Movement speed value"},
      {"address": "0xF2", "name": "scroll_state", "size": 1, "description": "Scroll/animation state"},
      {"address": "0xF3", "name": "col_draw_counter", "size": 1, "description": "Column draw counter"}
    ]
  },

