    {
      "id": "dd2_main_loop",
      "class_id": "game:game_loop",
      "name": "DD2 Main Loop",
      "description": "Arcade game loop — exact ROM flow replication",
      "phases": [
        {"id": "input", "handler": "processInput", "order": 1},
        {"id": "ai", "handler": "updateEnemyAI", "order": 2},
        {"id": "physics", "handler": "updatePhysics", "order": 3},
        {"id": "collision", "handler": "checkCollisions", "order": 4},
        {"id": "combat", "handler": "processCombat", "order": 5},
        {"id": "animation", "handler": "updateAnimations", "order": 6},
        {"id": "camera", "handler": "updateCamera", "order": 7},
        {"id": "bg_scroll", "handler": "updateBackground", "order": 8},
        {"id": "render_bg", "handler": "renderBackground", "order": 9},
        {"id": "render_sprites", "handler": "renderSprites", "order": 10},
        {"id": "render_hud", "handler": "renderHUD", "order": 11},
        {"id": "sound", "handler": "updateSound", "order": 12}
      ]
